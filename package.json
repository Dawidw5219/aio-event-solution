{
	"name": "aio-event-solution",
	"version": "1.2.7",
	"license": "GPL-2.0-or-later",
	"repository": {
		"type": "git",
		"url": "https://github.com/Dawidw5219/aio-event-solution.git"
	},
	"scripts": {
		"prep": "postcss src/assets/css/admin.css -o src/assets/css/generated/admin.css && postcss src/assets/css/frontend.css -o src/assets/css/generated/frontend.css",
		"dev": "pnpm run prep && grunt dev",
		"dev:local": "pnpm run prep && grunt dev",
		"dev:ftp": "pnpm run prep && grunt dev:ftp",
		"build": "pnpm run prep && grunt build",
		"deploy": "pnpm run build && ghdeploy --release 'builds/aio-event-solution-{version}.zip'",
		"deploy:wp": "grunt deploy:wp",
		"lint": "grunt lint",
		"assets": "grunt assets",
		"i18n:pot": "grunt makepot",
		"i18n:compile": "for po in src/languages/*.po; do [ -f \"$po\" ] && msgfmt \"$po\" -o \"${po%.po}.mo\" && echo \"Compiled: $(basename $po)\"; done",
		"i18n": "pnpm i18n:pot && pnpm i18n:compile"
	},
	"devDependencies": {
		"autoprefixer": "^10.4.16",
		"dotenv": "^16.4.5",
		"grunt": "^1.6.1",
		"grunt-contrib-compress": "^2.0.0",
		"grunt-contrib-cssmin": "^5.0.0",
		"grunt-contrib-uglify": "^5.2.2",
		"grunt-contrib-watch": "^1.1.0",
		"grunt-exec": "^3.0.0",
		"grunt-ftp-push": "^1.2.1",
		"grunt-sync": "^0.8.2",
		"grunt-wp-i18n": "^1.0.3",
		"postcss": "^8.4.32",
		"postcss-cli": "^11.0.1",
		"tailwindcss": "^3.4.0"
	}
}
